# SPDX-License-Identifier: Apache-2.0
# Example environment for Artesian. Copy to `.env` and adjust. Nothing here is required to start:
# the zero-infra defaults (local files + sqlite-vec) work out of the box.

# --- Core ---
# Config + data home (default: ~/.artesian)
ARTESIAN_HOME=
# Root of the human-readable memory store (OKF markdown/json). Default: $ARTESIAN_HOME/memory
ARTESIAN_MEMORY_ROOT=
# Optional hint surfaced in MCP tool descriptions (e.g. a project name) to steer the agent.
ARTESIAN_MCP_TOOL_HINT=

# --- Vector backend (optional; sqlite-vec is the zero-infra default) ---
# Qdrant endpoint, used when the `qdrant` feature/profile is enabled.
QDRANT_URL=http://localhost:6333
# Some deployments expose REST on a separate URL.
QDRANT_REST_URL=
QDRANT_API_KEY=

# --- ACC judge / compressor LLM (optional; OpenAI-compatible) ---
# Works with OpenAI or any OpenAI-compatible local server (LM Studio, Ollama, mlx_lm.server).
# Set the base URL per provider in artesian.toml ([acc.judge] / [acc.compressor]); this key is used
# only when the provider requires one. Leave empty to run the deterministic gate with no LLM.
OPENAI_API_KEY=

# --- Advanced (rarely needed) ---
# Per-process lock dir for benchmark/parallel isolation.
# ARTESIAN_LANE_LOCK_DIR=
