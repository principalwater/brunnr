/target/
/target
/.artesian/
**/.artesian/
/artesian.toml
**/*.rs.bk
.DS_Store
.idea/
.vscode/
*.log
/junit.xml
/benchmarks/results/*/timing.jsonl
*.tmp
*.swp
*.swo
*.env
*.env.*
!.env.example
/benchmarks/results/*/raw.jsonl

# procedural benchmark corpora (regenerated deterministically by tools/generate_corpus.py)
/benchmarks/xl-corpus/
/benchmarks/session-corpus/
/benchmarks/mid-corpus/
/benchmarks/mega-corpus/

# large-source-doc benchmark corpus (generated by tools/generate_large_source_corpus.py)
/benchmarks/large-source-corpus/

# Downloaded benchmark datasets (not vendored)
benchmarks/comparison/data/

# fastembed model cache
.fastembed_cache/

# MkDocs build output (the Pages workflow builds fresh)
/site/

# Artesian runtime memory bundles generated when the server/CLI runs inside a crate dir
crates/*/memory/
crates/*/.artesian/
